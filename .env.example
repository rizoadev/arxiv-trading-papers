# Environment Variables Template
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
DEBUG=True

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cryptoai
DATABASE_USER=cryptoai_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://cryptoai_user:your_secure_password_here@localhost:5432/cryptoai

# TimescaleDB
TIMESCALE_ENABLED=True

# =============================================================================
# REDIS CACHE
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CRYPTOAI TRADING SYSTEM
# =============================================================================

# LLM APIs
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000

ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=2000

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Exchange APIs (for trading)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=True  # Use testnet for development

COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret

KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

# On-Chain Data
GLASSNODE_API_KEY=your_glassnode_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# Social Media APIs
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=cryptoai_bot_v1

TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# =============================================================================
# CRYPTOWATCH SURVEILLANCE
# =============================================================================

# Alert Channels
TELEGRAM_CHAT_ID=your_telegram_chat_id
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@cryptowatch.io

# Alert Settings
ALERT_SEVERITY_FILTER=LOW,MEDIUM,HIGH,CRITICAL
ALERT_RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# API & WEB
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

SECRET_KEY=your_super_secret_key_for_jwt_signing
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# =============================================================================
# MONITORING
# =============================================================================

PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your_grafana_api_key

# =============================================================================
# CLOUD (AWS/GCP)
# =============================================================================

# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cryptoai-data

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
GCP_PROJECT_ID=your_gcp_project_id

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Capital
TOTAL_CAPITAL=500000  # $500K
INITIAL_POSITION_SIZE=0.01  # 1% of capital
MAX_POSITION_SIZE=0.05  # 5% max per position

# Risk
MAX_DAILY_LOSS=0.08  # 8% daily loss limit
MAX_DRAWDOWN=0.15  # 15% max drawdown
VAR_CONFIDENCE=0.95  # 95% VaR

# Leverage
MAX_LEVERAGE=3.0  # 3x max leverage
LEVERAGE_CALM=5.0
LEVERAGE_NORMAL=3.0
LEVERAGE_ELEVATED=2.0
LEVERAGE_CRISIS=1.0

# =============================================================================
# CRYPTOWATCH SUBSCRIPTIONS
# =============================================================================

STRIPE_API_KEY=sk_test_your_stripe_api_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PRICING_PREMIUM_MONTHLY=99
PRICING_INSTITUTIONAL_MONTHLY=5000
PRICING_DEFI_MONTHLY=10000

# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_WHALE_ALERTS=True
ENABLE_MANIPULATION_DETECTION=True
ENABLE_PUMP_GROUP_DETECTION=True
ENABLE_DEFİ_MONITORING=False  # Enable in Phase 4
ENABLE_AUTO_TRADING=False  # Enable only after paper trading validation

# =============================================================================
# PERFORMANCE
# =============================================================================

CACHE_TTL_SECONDS=300  # 5 minutes
BATCH_SIZE=64
INFERENCE_BATCH_SIZE=32

# =============================================================================
# SECURITY
# =============================================================================

ENCRYPTION_KEY=your_32_byte_encryption_key_here
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_SECRET_KEY=your_csrf_secret_key

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Use testnet/sandbox for development
USE_TESTNET=True
PAPER_TRADING=True
MOCK_DATA=False

# Auto-reload for development
AUTO_RELOAD=True
